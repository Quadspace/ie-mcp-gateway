# IE.AI MCP Gateway — Environment Configuration
# ================================================
# Copy this file to ~/.config/ie-mcp/.env and fill in your values.
# This file is chmod 600 — only you can read it.

# ── Required ──────────────────────────────────────────────────────────────────

# Your ngrok auth token (from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Absolute path to the project you want Claude Code to work in by default.
# Claude Code will run all commands from this directory.
PROJECT_PATH=/Users/YOUR_USERNAME/projects/YOUR_PROJECT

# ── Optional: Server Settings ─────────────────────────────────────────────────

# Port for the MCP gateway (default: 8765)
MCP_PORT=8765

# Port for the visual dashboard (default: 4041)
# NOTE: Do NOT use 4040 — that is ngrok's own admin UI.
DASHBOARD_PORT=4041

# Maximum number of concurrent Claude Code jobs (default: 3)
# M1 Pro: 2, M2 Pro: 3, M4 Pro: 4-6
MAX_WORKERS=3

# Rate limit: max requests per minute per user (default: 60)
RATE_LIMIT_RPM=60

# How many days to keep task context files before auto-deleting (default: 7)
CONTEXT_TTL_DAYS=7

# Path to the claude binary (default: claude)
# Run 'which claude' to find the correct path if needed.
CLAUDE_BINARY=claude
