# IE.AI MCP Gateway v7.0.0 — Environment Configuration
# =====================================================
# Copy this to ~/.config/ie-mcp/.env and fill in your values.
# The gateway loads this file on startup via python-dotenv.

# OpenRouter API Key (get one at https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Gateway authentication token (clients use this as Bearer token)
GATEWAY_TOKEN=your-gateway-token-here

# Path to the Claude Code CLI binary
# macOS: usually ~/.local/bin/claude or /usr/local/bin/claude
# Linux: usually ~/.local/bin/claude
CLAUDE_BIN=/Users/your-username/.local/bin/claude

# Default project directory for Claude Code to work in
PROJECT_PATH=/path/to/your/project

# ngrok domain for public access (get one at https://dashboard.ngrok.com/domains)
NGROK_DOMAIN=your-domain.ngrok.app

# Gateway port (default: 8765)
GATEWAY_PORT=8765
